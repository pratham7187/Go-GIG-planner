# App
APP_NAME=Vehicle Image Processing Pipeline
ENV=development
LOG_LEVEL=INFO

# Storage
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# Database
DATABASE_URL=sqlite:///./data/app.db

# Gemini (OPTIONAL — if unset, GeminiAnalyzer is skipped gracefully)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Processing
RETRY_LIMIT=2

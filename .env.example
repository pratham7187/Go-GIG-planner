# App
APP_NAME=Vehicle Image Processing Pipeline
ENV=development
LOG_LEVEL=INFO

# Storage
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# Database
DATABASE_URL=sqlite:///./data/app.db

# Gemini (OPTIONAL — if unset, GeminiAnalyzer is skipped gracefully)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Processing
RETRY_LIMIT=2

# CORS — comma-separated origins or ["*"] for all (restrict in production)
# CORS_ORIGINS=["https://your-frontend.netlify.app"]

# ──────────────────────────────────────────────────
# Railway deployment notes:
# ──────────────────────────────────────────────────
# 1. PORT is injected automatically by Railway — do NOT set it here.
# 2. Set ENV=production on Railway.
# 3. Attach a Railway Volume and mount it at /app/persist, then set:
#      UPLOAD_DIR=/app/persist/uploads
#      DATABASE_URL=sqlite:////app/persist/app.db
#    This keeps your database and uploads across deploys.
